{
  "name": "kino_pos",
  "version": "1.0.1",
  "productName": "Kino POS",
  "description": "Punto de venta para tienda de gorras y playeras",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "build:css": "tailwindcss -i ./renderer/css/input.css -o ./renderer/css/output.css",
    "watch:css": "tailwindcss -i ./renderer/css/input.css -o ./renderer/css/output.css --watch",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild:native",
    "start": "npm run rebuild:native && npm run build:css && electron .",
    "dev": "npm run watch:css & electron .",
    "pack": "npm run build:css && ELECTRON_BUILDER_DISABLE_ELECTRON_REBUILD=true electron-builder --dir",
    "dist:linux": "npm run build:css && ./node_modules/.bin/electron-rebuild -f -w better-sqlite3 && electron-builder --linux deb AppImage"
  },
  "keywords": [],
  "author": "Kino Store",
  "homepage": "https://kino.store",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/forms": "^0.5.0",
    "autoprefixer": "^10.4.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.19"
  },
  "build": {
    "appId": "com.kino.pos",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "database/**/*.js",
      "database/**/*.json",
      "package.json",
      "node_modules/better-sqlite3/build/Release/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/build/**/*"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "build/pwa-512x512.png",
      "category": "Office",
      "maintainer": "Kino Store"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "electronDist": "./node_modules/electron/dist",
    "nativeRebuilder": "legacy"
  }
}
